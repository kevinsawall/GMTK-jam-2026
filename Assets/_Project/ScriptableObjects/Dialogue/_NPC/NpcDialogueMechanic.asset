  npcId: mechanic-npc
  npcDisplayName: Mechanic
  portrait: {fileID: 0}
  entries:
  - entryId: first-talk
    requiredState: 0
    requiredFlag: 
    requiredItem: {fileID: 0}
    lines:
    - speaker: 0
      text: "Oh no, oh no, oh no. Something\u2019s wrong. An engine part\u2019s missing."
    - speaker: 0
      text: "I should have listened to my grandda. He used to say the rules are to
        be followed precisely, but I thought I\u2019d check this later. And now\u2026
        it\u2019s too late!"
    - speaker: 0
      text: "Oh, grandda. Look at this photo, it\u2019s me and my grandda\u2019s
        holding me\u2026"
    - speaker: 0
      text: "My da\u2019s there, too. But he\u2019s never been around much, having
        his career and all that..."
    - speaker: 0
      text: "Listen, I can\u2019t leave this unattended, or we\u2019ll crash. Help
        me find the engine part, I beg you! It should be somewhere on the train.
        Hurry!"
    actions:
    - type: 6
      stringValue: 
      item: {fileID: 11400000, guid: e5189ca137c624c61899108b68fb2247, type: 2}
      nextNpcState: 2
    - type: 4
      stringValue: 
      item: {fileID: 0}
